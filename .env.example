# Copy this file to .env and fill in your keys.
# Only OPENAI_API_KEY is required. TAVILY_API_KEY is optional (web-search fallback).

OPENAI_API_KEY=your_key_here
TAVILY_API_KEY=optional_key_here

# Optional: override the chat model (defaults to gpt-4o-mini).
# Keep this configurable so it can be swapped for Claude later.
CHAT_MODEL=gpt-4o-mini
